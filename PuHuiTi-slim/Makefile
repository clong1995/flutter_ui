# otf
slim_3500_regular_otf_run:
	pyftsubset source/AlibabaPuHuiTi-3-55-Regular.otf \
    --unicodes="U+0020-007E,U+00A7,U+00A9,U+00AE,U+00B1,U+00D7,U+00F7" \
    --text-file=sc_3500.txt \
    --layout-features="*" \
    --output-file=slim/sc_3500/AlibabaPuHuiTi-3-55-Regular.otf

slim_3500_medium_otf_run:
	pyftsubset source/AlibabaPuHuiTi-3-65-Medium.otf \
    --unicodes="U+0020-007E,U+00A7,U+00A9,U+00AE,U+00B1,U+00D7,U+00F7" \
    --text-file=sc_3500.txt \
    --layout-features="*" \
    --output-file=slim/sc_3500/AlibabaPuHuiTi-3-65-Medium.otf

slim_3500_bold_otf_run:
	pyftsubset source/AlibabaPuHuiTi-3-85-Bold.otf \
    --unicodes="U+0020-007E,U+00A7,U+00A9,U+00AE,U+00B1,U+00D7,U+00F7" \
    --text-file=sc_3500.txt \
    --layout-features="*" \
    --output-file=slim/sc_3500/AlibabaPuHuiTi-3-85-Bold.otf

